# Auto-generated Dockerfile for grade-mle-task-agent-em
FROM gcr.io/emily-dev-478705/byoa-base:latest

# Install additional dependencies if requirements.txt exists
COPY requirements.txt* /app/
RUN if [ -f /app/requirements.txt ]; then \
      uv pip install --no-cache -r /app/requirements.txt; \
    fi

# Copy custom agent files
COPY . /app/

# Start services
CMD ["/app/start-services.sh"]
